# Database
DATABASE_URL=postgresql+asyncpg://aiops_user:aiops_pass@localhost:5432/aiops

# OpenAI (diagnosis + embeddings)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone (runbook RAG)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aiops-runbooks
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=ecommerce.events
KAFKA_TOPIC_CORRELATED=incidents.correlated

# API
API_HOST=0.0.0.0
API_PORT=8000

# Simulator (fake e-commerce service)
SIMULATOR_HOST=0.0.0.0
SIMULATOR_PORT=8010

# OpenTelemetry (optional OTLP endpoint for local collectors)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ecommerce-simulator
